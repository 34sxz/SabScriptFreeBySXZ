jumpSliderButton.AutoButtonColor = false
 
-- Variables
local isEnabled = false
local speedValue = 50
local jumpValue = 50
local defaultWalkSpeed = 16
local defaultJumpPower = 50
 
-- Slider functionality
local function updateSlider(slider, button, value, label)
    local sliderSize = slider.AbsoluteSize.X
    local buttonSize = button.AbsoluteSize.X
    local maxPosition = sliderSize - buttonSize
    local position = (value / 100) * maxPosition
    button.Position = UDim2.new(0, position, -0.5, 0)
    label.Text = label.Name == "SpeedLabel" and "Speed: " .. value or "Jump: " .. value
end
 
-- Speed slider dragging
local speedDragging = false
speedSliderButton.MouseButton1Down:Connect(function()
    speedDragging = true
end)
 
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if speedDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local relativeX = input.Position.X - speedSlider.AbsolutePosition.X
        local sliderSize = speedSlider.AbsoluteSize.X
        local buttonSize = speedSliderButton.AbsoluteSize.X
        local maxPosition = sliderSize - buttonSize
        local position = math.clamp(relativeX - buttonSize/2, 0, maxPosition)
        speedSliderButton.Position = UDim2.new(0, position, -0.5, 0)
        speedValue = math.floor((position / maxPosition) * 100)
        speedLabel.Text = "Speed: " .. speedValue
        
        if isEnabled then
            character.Humanoid.WalkSpeed = defaultWalkSpeed + (speedValue * 0.5)
        end
    end
end)
 
game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        speedDragging = false
    end
end)
 
-- Jump slider dragging
local jumpDragging = false
jumpSliderButton.MouseButton1Down:Connect(function()
    jumpDragging = true
end)
 
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if jumpDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local relativeX = input.Position.X - jumpSlider.AbsolutePosition.X
        local sliderSize = jumpSlider.AbsoluteSize.X
        local buttonSize = jumpSliderButton.AbsoluteSize.X
        local maxPosition = sliderSize - buttonSize
        local position = math.clamp(relativeX - buttonSize/2, 0, maxPosition)
        jumpSliderButton.Position = UDim2.new(0, position, -0.5, 0)
        jumpValue = math.floor((position / maxPosition) * 100)
        jumpLabel.Text = "Jump: " .. jumpValue
        
        if isEnabled then
            character.Humanoid.JumpPower = defaultJumpPower + (jumpValue * 0.5)
        end
    end
end)
 
game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        jumpDragging = false
    end
end)
 
-- Toggle button functionality
toggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    
    if isEnabled then
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        toggleButton.Text = "ON"
        character.Humanoid.WalkSpeed = defaultWalkSpeed + (speedValue * 0.5)
        character.Humanoid.JumpPower = defaultJumpPower + (jumpValue * 0.5)
    else
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        toggleButton.Text = "OFF"
        character.Humanoid.WalkSpeed = defaultWalkSpeed
        character.Humanoid.JumpPower = defaultJumpPower
    end
end)
 
-- Initialize sliders
updateSlider(speedSlider, speedSliderButton, speedValue, speedLabel)
updateSlider(jumpSlider, jumpSliderButton, jumpValue, jumpLabel)

        local inner = Instance.new("Frame", outer); inner.Size = UDim2.new(1, -4, 1, -4); inner.Position = UDim2.new(0, 2, 0, 2)
        inner.BackgroundColor3 = LIGHT_PURPLE; inner.BackgroundTransparency = 0.1; inner.BorderSizePixel = 0

local function createBtn(parent, y, text, defaultColor)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, 0, 0, 50); btn.Position = UDim2.new(0, 0, 0, y)
    btn.BackgroundColor3 = defaultColor or BTN_DARK; btn.TextColor3 = Color3.fromRGB(240, 240, 240)

        local nm = Instance.new("TextLabel", bb); nm.Size = UDim2.new(0, 140, 0, 22); nm.Position = UDim2.new(0.5, -70, 1, 4)
        nm.BackgroundTransparency = 1; nm.Text = plr.DisplayName; nm.TextColor3 = LIGHT_PURPLE
        nm.TextStrokeTransparency = 0.2; nm.TextStrokeColor3 = ACCENT_PURPLE; nm.Font = Enum.Font.GothamBold; nm.TextSize = 13
        local dl = Instance.new("TextLabel", bb); dl.Size = UDim2.new(0, 140, 0, 18); dl.Position = UDim2.new(0.5, -70, 1, 26)
        dl.BackgroundTransparency = 1; dl.Text = "0m | 0s"; dl.TextColor3 = Color3.fromRGB(255, 220, 100); dl.Font = Enum.Font.Gotham; dl.TextSize = 11
        espInst[plr] = {bb = bb, distLbl = dl, spawnTime = tick()}
    end
    build()
    local c1 = plr.CharacterAdded:Connect(function()
        task.wait(0.5); if espInst[plr] then espInst[plr].bb:Destroy(); espInst[plr] = nil end; build()
    end)
    local c2 = plr.CharacterRemoving:Connect(function()
        if espInst[plr] then espInst[plr].bb:Destroy(); espInst[plr] = nil end
    end); espConns[plr] = {c1, c2}
end

local function removePlayerESP(plr)
    if espInst[plr] then espInst[plr].bb:Destroy(); espInst[plr] = nil end
    if espConns[plr] then for _, c in pairs(espConns[plr]) do c:Disconnect() end; espConns[plr] = nil end
end

local function enableESPPlayers()
    for _, p in ipairs(Players:GetPlayers()) do addPlayerESP(p) end
    espJoin  = Players.PlayerAdded:Connect(addPlayerESP)
    espLeave = Players.PlayerRemoving:Connect(removePlayerESP)
end
local function disableESPPlayers()
    if espJoin  then espJoin:Disconnect();  espJoin  = nil end
    if espLeave then espLeave:Disconnect(); espLeave = nil end
    for _, p in ipairs(Players:GetPlayers()) do removePlayerESP(p) end
end


-- Laser
local function fireLaserAt(targetPlr)
    if laserCooldown then return end; laserCooldown = true
    task.spawn(function()
        local char = player.Character; if not char then laserCooldown = false; return end
        local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then laserCooldown = false; return end
        local laser = player.Backpack:FindFirstChild("Laser Cape") or char:FindFirstChild("Laser Cape")
        if not laser then laserCooldown = false; return end
        if laser.Parent == player.Backpack then hum:EquipTool(laser); task.wait(0.15) end
        local eq = char:FindFirstChild("Laser Cape"); if not eq then laserCooldown = false; return end
        local tc = targetPlr.Character; if not tc then laserCooldown = false; return end
        local torso = tc:FindFirstChild("UpperTorso") or tc:FindFirstChild("Torso") or tc:FindFirstChild("HumanoidRootPart")
        if torso then
            local fired = false
            for _, v in pairs(eq:GetDescendants()) do
                if v:IsA("RemoteEvent") then pcall(function() v:FireServer(torso.Position, torso) end); fired = true; break end
            end; if not fired then pcall(function() eq:Activate() end) end
        end; task.wait(1.2); laserCooldown = false
    end)
end

-- Defense loop
RunService.Heartbeat:Connect(function()
    if not autoDefenseEnabled and not autoKickEnabled and not autoLaserEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos = plr.Character.HumanoidRootPart.Position; local nearBase = false
            for _, bp in ipairs(basePositions) do
                if (pos - bp).Magnitude <= BASE_DISTANCE then
                    nearBase = true
                    if autoDefenseEnabled then fireOnPlayer(plr) end
                    if autoKickEnabled    then player:Kick("UGC Protected"); return end
                    if autoLaserEnabled   then fireLaserAt(plr) end; break
                end
            end
            if antiTPEnabled and lastPositions[plr] then
                if (pos - lastPositions[plr]).Magnitude >= TP_DISTANCE then
                    for _, bp in ipairs(basePositions) do
                        if (pos - bp).Magnitude <= BASE_DISTANCE then
                            if autoDefenseEnabled then fireOnPlayer(plr) end
                            if autoKickEnabled    then player:Kick("UGC Protected"); return end
                        end
                    end
                end
            end
            lastPositions[plr] = pos
            if not nearBase then triggeredPlayers[plr] = nil end
        end
    end
end)


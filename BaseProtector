    allowDB = true

    local ok = fireBasePrompt()

    if ok then
        isAllowed = not isAllowed
        local col = isAllowed and BTN_GREEN or BTN_RED
        bAllow.Text = isAllowed and "🟢  Base Access : ALLOW" or "🔴  Base Access : DISALLOW"
        bAllow:SetAttribute("ActiveColor", col)
        TweenService:Create(bAllow, TweenInfo.new(0.3), {BackgroundColor3 = col}):Play()
    else
        bAllow.Text = "⚠️  Prompt Not Found"
        task.wait(1.5)
        bAllow.Text = isAllowed and "🟢  Base Access : ALLOW" or "🔴  Base Access : DISALLOW"
    end

    task.wait(1); allowDB = false
end)


-- Anti Ragdoll
local ARConns = {}
local function enableAntiRagdoll()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid")
    local anim = hum:WaitForChild("Animator")
    local function isRag()
        local s = hum:GetState()
        return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll
            or s == Enum.HumanoidStateType.FallingDown or s == Enum.HumanoidStateType.GettingUp
    end
    local function clean()
        for _, o in pairs(char:GetDescendants()) do
            if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint") or o:IsA("HingeConstraint")
            or o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") then o:Destroy()
            elseif o:IsA("Motor6D") then o.Enabled = true end
        end
        for _, t in pairs(anim:GetPlayingAnimationTracks()) do
            local n = t.Animation and t.Animation.Name:lower() or ""
            if n:find("rag") or n:find("fall") or n:find("hurt") or n:find("down") then t:Stop(0) end
        end
    end
    table.insert(ARConns, hum.StateChanged:Connect(function()
        if isRag() then hum:ChangeState(Enum.HumanoidStateType.Running); clean() end
    end))
    table.insert(ARConns, RunService.Heartbeat:Connect(function() if isRag() then clean() end end))
    table.insert(ARConns, player.CharacterAdded:Connect(function(c)
        char = c; hum = c:WaitForChild("Humanoid"); anim = hum:WaitForChild("Animator"); clean()
    end)); clean()
end
local function disableAntiRagdoll()
    for _, c in pairs(ARConns) do c:Disconnect() end; ARConns = {}
end

-- Trap ESP
local trapESP = {} local processedTraps = {} local trapBarriers = {}
local trapWatchConn, antiTrapWatchConn

local function createTrapESP(model)
    if trapESP[model] then return end
    local pp = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart"); if not pp then return end
    local data = {}
    local hl = Instance.new("SelectionBox"); hl.Adornee = model; hl.Color3 = NEON_PURPLE
    hl.LineThickness = 0.08; hl.SurfaceColor3 = NEON_PURPLE; hl.SurfaceTransparency = 0.55; hl.Parent = workspace; data.hl = hl
    local bb = Instance.new("BillboardGui"); bb.Adornee = pp; bb.Size = UDim2.new(0, 90, 0, 40)
    bb.StudsOffset = Vector3.new(0, 4, 0); bb.AlwaysOnTop = true; bb.MaxDistance = 300; bb.Parent = workspace
    local l1 = Instance.new("TextLabel", bb); l1.Size = UDim2.new(1, 0, 0.6, 0); l1.BackgroundTransparency = 1
    l1.Text = "⚠ Trap"; l1.TextColor3 = LIGHT_PURPLE; l1.TextStrokeTransparency = 0.1; l1.Font = Enum.Font.GothamBlack; l1.TextSize = 14
    local l2 = Instance.new("TextLabel", bb); l2.Size = UDim2.new(1, 0, 0.4, 0); l2.Position = UDim2.new(0, 0, 0.6, 0)
    l2.BackgroundTransparency = 1; l2.Text = "0s"; l2.TextColor3 = Color3.fromRGB(255, 220, 100); l2.Font = Enum.Font.GothamBold; l2.TextSize = 12
    data.bb = bb; data.timerLbl = l2; data.spawnTime = tick(); trapESP[model] = data
end

local function removeTrapESP(model)
    local d = trapESP[model]; if not d then return end
    if d.hl and d.hl.Parent then d.hl:Destroy() end
    if d.bb and d.bb.Parent then d.bb:Destroy() end; trapESP[model] = nil
end

local function createTrapBarrier(model)
    if processedTraps[model] then return end; processedTraps[model] = true
    local cf, sz = model:GetBoundingBox()
    local bar = Instance.new("Part"); bar.Name = "TrapBarrier"; bar.Size = sz + Vector3.new(6, sz.Y, 6)
    bar.CFrame = cf; bar.Anchored = true; bar.CanCollide = true; bar.CanQuery = false
    bar.Transparency = 0.35; bar.Material = Enum.Material.Neon; bar.Color = NEON_PURPLE; bar.Parent = workspace
    trapBarriers[model] = bar
    for _, p in pairs(model:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false; p.Transparency = 1 end
        if p:IsA("TouchTransmitter") then p:Destroy() end
    end
end

local function enableESPTrap()
    for _, o in pairs(workspace:GetDescendants()) do
        if o:IsA("Model") and o.Name:lower():find("trap") then
            local pp = o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart"); if pp then createTrapESP(o) end
        end
    end
    trapWatchConn = workspace.DescendantAdded:Connect(function(o)
        task.wait(0.3)
        if o:IsA("Model") and o.Name:lower():find("trap") and o.Parent then
            createTrapESP(o)
            if antiTrapEnabled then
                local pp = o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart")
                if pp and pp.Anchored then createTrapBarrier(o) end
            end
        end
    end)
end
local function disableESPTrap()
    if trapWatchConn then trapWatchConn:Disconnect(); trapWatchConn = nil end
    for m in pairs(trapESP) do removeTrapESP(m) end; trapESP = {}
end

local function enableAntiTrap()
    for m in pairs(trapESP) do
        local pp = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
        if pp and pp.Anchored then createTrapBarrier(m) end
    end
    antiTrapWatchConn = workspace.DescendantAdded:Connect(function(o)
        if o:IsA("Model") and o.Name:lower():find("trap") then
            task.wait(0.5)
            if o.Parent then
                local pp = o.PrimaryPart or o:FindFirstChildWhichIsA("BasePart")
                if pp and pp.Anchored then createTrapESP(o); createTrapBarrier(o) end
            end
        end
    end)
end
local function disableAntiTrap()
    if antiTrapWatchConn then antiTrapWatchConn:Disconnect(); antiTrapWatchConn = nil end
    for m, bar in pairs(trapBarriers) do
        if bar and bar.Parent then bar:Destroy() end
        if m and m.Parent then
            for _, p in pairs(m:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true; p.Transparency = 0 end
            end
        end
    end; trapBarriers = {}; processedTraps = {}
end

